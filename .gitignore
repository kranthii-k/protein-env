# ── Python artefacts ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── uv ───────────────────────────────────────────────────────────────────────
uv.lock

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Test & coverage artefacts ─────────────────────────────────────────────────
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
junit*.xml

# ── Model weights & large binary files ───────────────────────────────────────
# ESM2 weights are downloaded at runtime; do not commit them.
*.bin
*.safetensors
*.pt
*.pth

# ── Editor / OS noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
*.key
