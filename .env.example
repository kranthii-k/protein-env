# ProteinEnv — environment variables
# Copy this file to .env and fill in your values.
# Never commit the populated .env file.

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Token with at least read access to download ESM2 model weights.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server configuration ──────────────────────────────────────────────────────
# Port the FastAPI / uvicorn server listens on (default: 8000).
PORT=8000

# Log level for the application logger (DEBUG | INFO | WARNING | ERROR).
LOG_LEVEL=INFO

# ── Model loading ─────────────────────────────────────────────────────────────
# Set to "cpu" to force CPU-only inference even when a GPU is available.
# Leave unset to auto-detect device via torch.cuda.is_available().
DEVICE=cpu

# ── OpenEnv orchestrator ──────────────────────────────────────────────────────
# Base URL of the OpenEnv orchestrator that will call this environment.
# Used for registration / health-check callbacks (optional in local dev).
OPENENV_ORCHESTRATOR_URL=http://localhost:9000
